@model IEnumerable<InventoryOrderingSystem.Models.Database.Product>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-uppercase" style="font-family: 'Montserrat';">Inventory Management</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Item</a>
</div>

<div class="card mb-4 shadow-sm border-0">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-2">
            <div class="col-md-10">
                <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Search name, code, or try 'low stock', 'out of stock'..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100">Search</button>
            </div>
        </form>
        <div class="mt-2">
            <small class="text-muted">
                Quick Filters:
                <a href="@Url.Action("Index", new { searchString = "low stock" })" class="badge bg-warning text-dark text-decoration-none">Low Stock</a>
                <a href="@Url.Action("Index", new { searchString = "out of stock" })" class="badge bg-danger text-decoration-none">Out of Stock</a>
                <a href="@Url.Action("Index", new { searchString = "" })" class="badge bg-secondary text-decoration-none">Clear</a>
            </small>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead style="background-color: var(--forest-green); color: white;">
                <tr>
                    <th class="ps-4">Code</th>
                    <th>Name</th>
                    <th style="width: 160px;">Price</th>
                    <th style="width: 180px;">Stock & Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-muted">@item.ProductCode</td>
                        <td>@item.Name</td>
                        <form asp-action="UpdateInventory" method="post">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="hidden" name="searchString" value="@ViewBag.SearchString" />

                        <td>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">₱</span>
                                <input type="number" name="price" step="0.01" class="form-control" value="@item.Price" required />
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <input type="number" name="stock" class="form-control form-control-sm" value="@item.Stock" required />

                                    @if (item.Stock <= 0)
                                    {
                                    <span class="badge bg-danger" style="font-size: 0.7rem;">OUT OF STOCK</span>
                                    }
                                    else if (item.Stock <= 10)
                                    {
                                    <span class="badge bg-warning text-dark" style="font-size: 0.7rem;">LOW STOCK</span>
                                    }
                                    else
                                    {
                                    <span class="badge" style="background-color: var(--sage-green); font-size: 0.7rem;">HEALTHY</span>
                                    }
                            </div>
                        </td>
                        <td class="text-center">
                            <button type="submit" class="btn btn-sm btn-outline-success px-3">Save</button>
                        </td>
                        </form>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link shadow-none" asp-action="Index" asp-route-page="@i" asp-route-searchString="@ViewBag.SearchString"
                       style="@(i == ViewBag.CurrentPage ? "background-color: var(--forest-green); border-color: var(--forest-green); color: white;" : "color: var(--forest-green);")">
                        @i
                    </a>
                </li>
            }
        </ul>
    </nav>
}