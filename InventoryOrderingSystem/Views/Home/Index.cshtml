@{
    ViewData["Title"] = "Connection Test";
}

<div class="text-center">
    <h1>Database Test</h1>
    <hr />
    @if (ViewBag.DbStatus == "Connected!")
    {
        <div class="alert alert-success">
            <strong>Success!</strong> Your app is talking to the SQL Database.
            <br />Total Customers in DB: @ViewBag.CustomerCount
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <strong>Connection Failed!</strong>
            <p>@ViewBag.DbStatus</p>
        </div>
    }
</div>