@{
    ViewData["Title"] = "Connection Test";
}

<div class="text-center">
    @if (Context.Session.GetString("Role") != null)
    {
        <h2 class="text-success">Welcome back, @Context.Session.GetString("Role")!</h2>
        <p>Your ID is: @Context.Session.GetInt32("AdminId")@Context.Session.GetInt32("UserId")</p>
        <a asp-action="Logout" class="btn btn-danger">Logout</a>
    }
    else
    {
        <h2>You are not logged in.</h2>
        <a asp-action="Login" class="btn btn-primary">Go to Login</a>
    }
</div>