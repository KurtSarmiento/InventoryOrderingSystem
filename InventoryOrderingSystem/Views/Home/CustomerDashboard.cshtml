@model IEnumerable<InventoryOrderingSystem.Models.Database.Order>

<h2 class="text-uppercase mb-4" style="color: var(--deep-brown);">My Account Overview</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-white" style="background-color: var(--forest-green);">
            <div class="card-body text-center p-4">
                <h6 class="text-uppercase opacity-75">Total Orders</h6>
                <h1 class="display-4 fw-bold">@Model.Count()</h1>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-white" style="background-color: var(--sage-green);">
            <div class="card-body text-center p-4">
                <h6 class="text-uppercase opacity-75">Completed</h6>
                <h1 class="display-4 fw-bold">@Model.Count(o => o.Status == "Completed")</h1>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-white" style="background-color: #d4a373;">
            <div class="card-body text-center p-4">
                <h6 class="text-uppercase opacity-75">Pending Orders</h6>
                <h1 class="display-4 fw-bold">@Model.Count(o => o.Status == "Pending")</h1>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-bold py-3">
                <i class="bi bi-clock-history me-2 text-success"></i> RECENT ORDERS
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Order ID</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">No orders found.</td>
                                </tr>
                            }
                            @foreach (var order in Model.OrderByDescending(o => o.DateCreated).Take(10))
                            {
                                <tr>
                                    <td class="ps-3 fw-bold">#@order.OrderId.ToString("D5")</td>
                                    <td>@order.DateCreated.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <span class="badge @(order.Status == "Completed" ? "bg-success" : "bg-warning text-dark")">
                                            @order.Status
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-success">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-bold py-3">
                QUICK ACTIONS
            </div>
            <div class="card-body">
                <div class="d-grid gap-3">
                    <a asp-controller="Orders" asp-action="Create" class="btn btn-primary btn-lg p-3">
                        <i class="bi bi-cart-plus me-2"></i> Create New Order
                    </a>
                    <div class="p-3 border rounded bg-light">
                        <small class="text-muted d-block text-uppercase fw-bold mb-2">Account Support</small>
                        <p class="small mb-0">For order modifications or cancellations, please contact the administrator.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>