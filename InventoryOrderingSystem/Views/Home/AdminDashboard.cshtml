@model IEnumerable<InventoryOrderingSystem.Models.Database.Product>

<h2 class="text-uppercase mb-4" style="color: var(--deep-brown);">Executive Overview</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-white" style="background-color: var(--forest-green);">
            <div class="card-body text-center p-4">
                <h6 class="text-uppercase opacity-75">Active Customers</h6>
                <h1 class="display-4 fw-bold">@ViewBag.TotalCustomers</h1>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-white" style="background-color: var(--sage-green);">
            <div class="card-body text-center p-4">
                <h6 class="text-uppercase opacity-75">Total Products</h6>
                <h1 class="display-4 fw-bold">@ViewBag.TotalProducts</h1>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-white" style="background-color: #d4a373;">
            <div class="card-body text-center p-4">
                <h6 class="text-uppercase opacity-75">Pending Orders</h6>
                <h1 class="display-4 fw-bold">@ViewBag.PendingOrders</h1>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-bold text-danger py-3">
                <i class="bi bi-exclamation-triangle-fill"></i> LOW STOCK ALERTS
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th class="text-center">Remaining</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>@p.Name</td>
                                <td class="text-center">
                                    <span class="badge @(p.Stock <= 0 ? "bg-danger" : "bg-warning text-dark")">
                                        @p.Stock
                                    </span>
                                </td>
                                <td><a asp-controller="Products" asp-action="Index" asp-route-searchString="@p.ProductCode" class="btn btn-sm btn-link text-success p-0">Restock</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-bold py-3">
                QUICK ACTIONS
            </div>
            <div class="card-body">
                <div class="d-grid gap-3">
                    <a asp-controller="Orders" asp-action="Create" class="btn btn-primary btn-lg p-3">
                        <i class="bi bi-plus-lg"></i> Create New Order
                    </a>
                    <a asp-controller="Customers" asp-action="Create" class="btn btn-outline-success p-3">
                        Add New Customer
                    </a>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary p-3">
                        Inventory Audit
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>